{
  "name": "3rd-place-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "rm -rf .next && next dev",
    "prebuild": "lsof -iTCP:3000 -sTCP:LISTEN >/dev/null 2>&1 && { echo 'ERROR: dev server is running on port 3000. Stop it (Ctrl+C in the dev terminal) before running build.'; exit 1; } || true",
    "build": "next build",
    "postbuild": "node scripts/remove-hub-output.mjs",
    "start": "next start",
    "pr:create": "bash scripts/create-pr.sh",
    "gh:install": "bash scripts/install-gh-local.sh"
  },
  "dependencies": {
    "next": "^14.2.35",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "postcss": "^8",
    "tailwindcss": "^3.3.0",
    "typescript": "^5"
  }
}
